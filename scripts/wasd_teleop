#!/usr/bin/env python3

import select
import sys
import termios
import time
import tty

import rclpy
from geometry_msgs.msg import Twist
from rclpy.node import Node


class WasdTeleop(Node):
    def __init__(self):
        super().__init__('wasd_teleop')
        self.publisher = self.create_publisher(Twist, 'cmd_vel', 10)

        self.linear_speed = 1.3
        self.angular_speed = 3.0

        # Command state for each axis: -1, 0, +1
        self.linear_dir = 0
        self.angular_dir = 0
        self.current_linear = 0.0
        self.current_angular = 0.0

        # Deadman behavior for terminal input (no native key-up events):
        # when a key stops repeating, that axis returns to zero shortly after.
        self.input_timeout = 0.22
        self.last_linear_input = 0.0
        self.last_angular_input = 0.0
        self.last_published_linear = None
        self.last_published_angular = None
        self.timer = self.create_timer(0.02, self.on_timer)

        self.print_help()

    def print_help(self):
        self.get_logger().info(
            '\n'
            'WASD Teleop for /cmd_vel\n'
            '  Hold w: forward\n'
            '  Hold s: backward\n'
            '  Hold a: turn left\n'
            '  Hold d: turn right\n'
            '  Supports combos: w+a, w+d, s+a, s+d\n'
            '  Release key: that axis stops\n'
            '  x or space: stop\n'
            '  q/z: increase/decrease linear speed\n'
            '  e/c: increase/decrease angular speed\n'
            '  Ctrl-C: quit\n'
        )

    def publish_twist(self):
        msg = Twist()
        msg.linear.x = self.current_linear
        msg.angular.z = self.current_angular
        self.publisher.publish(msg)

    def update_motion(self):
        now = time.monotonic()
        if now - self.last_linear_input > self.input_timeout:
            self.linear_dir = 0
        if now - self.last_angular_input > self.input_timeout:
            self.angular_dir = 0

        self.current_linear = float(self.linear_dir) * self.linear_speed
        self.current_angular = float(self.angular_dir) * self.angular_speed

    def publish_if_changed(self):
        if (
            self.current_linear != self.last_published_linear
            or self.current_angular != self.last_published_angular
        ):
            self.publish_twist()
            self.last_published_linear = self.current_linear
            self.last_published_angular = self.current_angular

    def on_timer(self):
        self.update_motion()
        self.publish_if_changed()

    def handle_key(self, key: str):
        now = time.monotonic()

        if key == 'w':
            self.linear_dir = 1
            self.last_linear_input = now
        elif key == 's':
            self.linear_dir = -1
            self.last_linear_input = now
        elif key == 'a':
            self.angular_dir = 1
            self.last_angular_input = now
        elif key == 'd':
            self.angular_dir = -1
            self.last_angular_input = now
        elif key in ('x', ' '):
            self.linear_dir = 0
            self.angular_dir = 0
            self.last_linear_input = 0.0
            self.last_angular_input = 0.0
        elif key == 'q':
            self.linear_speed = min(self.linear_speed + 0.1, 3.0)
            self.get_logger().info(f'Linear speed: {self.linear_speed:.2f}')
        elif key == 'z':
            self.linear_speed = max(self.linear_speed - 0.1, 0.1)
            self.get_logger().info(f'Linear speed: {self.linear_speed:.2f}')
        elif key == 'e':
            self.angular_speed = min(self.angular_speed + 0.1, 5.0)
            self.get_logger().info(f'Angular speed: {self.angular_speed:.2f}')
        elif key == 'c':
            self.angular_speed = max(self.angular_speed - 0.1, 0.1)
            self.get_logger().info(f'Angular speed: {self.angular_speed:.2f}')
        else:
            return

        self.update_motion()
        self.publish_if_changed()


def get_key(timeout: float = 0.1):
    rlist, _, _ = select.select([sys.stdin], [], [], timeout)
    if rlist:
        return sys.stdin.read(1)
    return None


def main():
    if not sys.stdin.isatty():
        print('wasd_teleop needs an interactive terminal (TTY).')
        return

    rclpy.init()
    node = WasdTeleop()

    settings = termios.tcgetattr(sys.stdin)
    tty.setcbreak(sys.stdin.fileno())

    try:
        while rclpy.ok():
            key = get_key()
            if key is not None:
                node.handle_key(key)
            rclpy.spin_once(node, timeout_sec=0.0)
    except KeyboardInterrupt:
        pass
    finally:
        node.current_linear = 0.0
        node.current_angular = 0.0
        node.publish_twist()
        termios.tcsetattr(sys.stdin, termios.TCSADRAIN, settings)
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
