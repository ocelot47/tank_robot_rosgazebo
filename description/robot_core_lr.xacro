<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
	
	<xacro:include filename="inertial_macros.xacro"/>	

	<material name="white">
		<color rgba="1 1 1 1"/>
	</material>

	<material name="black">
		<color rgba="0 0 0 1"/>
	</material>

	<material name="yellow">
		<color rgba="1 1 0 1"/>
	</material>

	<!-- BASE LINK -->
	<link name="base_link">
		
	</link>

	<!-- Nav2 AMCL default uses base_footprint as robot base frame -->
	<joint name="base_footprint_joint" type="fixed">
		<parent link="base_link"/>
		<child link="base_footprint"/>
		<origin xyz="0 0 -0.10" rpy="0 0 0"/>
	</joint>

	<link name="base_footprint"/>

	<!-- Low-mounted ballast to keep CoM near the ground and reduce roll-over -->
	<joint name="ballast_joint" type="fixed">
		<parent link="base_link"/>
		<child link="ballast_link"/>
		<origin xyz="0 0 0.03" rpy="0 0 0"/>
	</joint>

	<link name="ballast_link">
		<xacro:inertial_box mass="2.2" x="0.25" y="0.18" z="0.04">
        	<origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
	</link>
	
	<!-- CHASSIS -->
	<joint name="chassis_joint" type="fixed">
		<parent link="base_link"/>
		<child link="chassis_link"/>
		<origin xyz="0 0 0"/>
	</joint>

	<link name="chassis_link">
		<visual>
			<!-- Scale/offset STL to match LR collision body (~0.8 x 0.4 x 0.05 at z=0.1) -->
			<origin xyz="0.5248 0.1928 0.1595" rpy="0 0 0"/>
			<geometry>
				<mesh filename="package://four_wheeled_robot/meshes/chassis_link.STL" scale="6.154 4.0 12.5"/>
			</geometry>
			<material name="white"/>
		</visual>
		<!-- Primitive fallback so the body is still visible if mesh rendering fails -->
		<visual>
			<origin xyz="0 0 0.1"/>
			<geometry>
				<box size="0.8 0.4 0.05"/>
			</geometry>
			<material name="white"/>
		</visual>
		
		<collision>
			<origin xyz="0 0 0.1"/>
			<geometry>
				<box size="0.8 0.4 0.05"/>
			</geometry>
		</collision>

		<xacro:inertial_box mass="0.5" x="0.8" y="0.4" z="0.05">
        	<origin xyz="0 0 0.1" rpy="0 0 0"/>
        </xacro:inertial_box>
	</link>

	<gazebo reference="chassis_link">
		<material>Gazebo/White</material>
	</gazebo>

	<!-- LIDAR -->
	<joint name="lidar_joint" type="fixed">
		<parent link="chassis_link"/>
		<child link="lidar_link"/>
		<origin xyz="0 0 0.18" rpy="0 0 0"/>
	</joint>

	<link name="lidar_link">
		<visual>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
				<cylinder radius="0.03" length="0.04"/>
			</geometry>
			<material name="black"/>
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
				<cylinder radius="0.03" length="0.04"/>
			</geometry>
		</collision>
		<xacro:inertial_cylinder mass="0.05" length="0.04" radius="0.03">
        	<origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
	</link>

	<gazebo reference="lidar_link">
		<sensor name="lidar_sensor" type="ray">
			<always_on>true</always_on>
			<visualize>true</visualize>
			<update_rate>8</update_rate>
			<pose>0 0 0 0 0 0</pose>
			<ray>
				<scan>
					<horizontal>
						<samples>360</samples>
						<resolution>1</resolution>
						<min_angle>-3.14159</min_angle>
						<max_angle>3.14159</max_angle>
					</horizontal>
				</scan>
				<range>
					<min>0.12</min>
					<max>8.0</max>
					<resolution>0.01</resolution>
				</range>
				<noise>
					<type>gaussian</type>
					<mean>0.0</mean>
					<stddev>0.01</stddev>
				</noise>
			</ray>
			<plugin name="gazebo_ros_lidar" filename="libgazebo_ros_ray_sensor.so">
				<ros>
					<remapping>~/out:=scan</remapping>
				</ros>
				<output_type>sensor_msgs/LaserScan</output_type>
				<frame_name>lidar_link</frame_name>
			</plugin>
		</sensor>
	</gazebo>

	<!-- WHEEL1 -->
	<joint name="wheel1_joint" type="continuous">
		<parent link="base_link"/>
		<child link="wheel1_link"/>
		<origin xyz="0.2 0.25 0" rpy="${-pi/2} 0 0"/>
		<axis xyz="0 0 1"/>
		<limit effort="80" velocity="20" />
	    <dynamics damping="1.0" friction="1.0" />
	</joint>

	<link name="wheel1_link">
		<visual>
			<origin xyz="0 0 0.0167" rpy="0 0 0"/>
			<geometry>
				<mesh filename="package://four_wheeled_robot/meshes/wheel1_Link.STL" scale="2.56 2.56 3.333"/>
			</geometry>
			<material name="yellow"/>
		</visual>
		<visual>
			<origin xyz="0 0 -0.005" rpy="0 0 0"/>
			<geometry>
				<mesh filename="package://four_wheeled_robot/meshes/tire1_Link.STL" scale="2.04 2.04 3.333"/>
			</geometry>
			<material name="black"/>
		</visual>
		<!-- Primitive fallback so wheel remains visible if mesh loading fails -->
		<visual>
			<geometry>
				<cylinder radius="0.1" length="0.1"/>
			</geometry>
			<material name="black"/>
		</visual>
		
		<collision>
			<geometry>
				<cylinder radius="0.1" length="0.1"/>
			</geometry>
		</collision>
		
		<xacro:inertial_cylinder mass="0.1" length="0.1" radius="0.1">
        	<origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
	</link>
	
	<gazebo reference="wheel1_link">
		<material>Gazebo/Black</material>
	</gazebo>	

	<!-- WHEEL2 -->
	<joint name="wheel2_joint" type="continuous">
		<parent link="base_link"/>
		<child link="wheel2_link"/>
		<origin xyz="0.2 -0.25 0" rpy="${pi/2} 0 0"/>
		<axis xyz="0 0 -1"/>
		<limit effort="80" velocity="20" />
	    <dynamics damping="1.0" friction="1.0" />
	</joint>

	<link name="wheel2_link">
		<visual>
			<origin xyz="0 0 0.0167" rpy="0 0 0"/>
			<geometry>
				<mesh filename="package://four_wheeled_robot/meshes/wheel2_Link.STL" scale="2.56 2.56 3.333"/>
			</geometry>
			<material name="yellow"/>
		</visual>
		<visual>
			<origin xyz="0 0 -0.005" rpy="0 0 0"/>
			<geometry>
				<mesh filename="package://four_wheeled_robot/meshes/tire2_Link.STL" scale="2.04 2.04 3.333"/>
			</geometry>
			<material name="black"/>
		</visual>
		<!-- Primitive fallback so wheel remains visible if mesh loading fails -->
		<visual>
			<geometry>
				<cylinder radius="0.1" length="0.1"/>
			</geometry>
			<material name="black"/>
		</visual>

		<collision>
			<geometry>
				<cylinder radius="0.1" length="0.1"/>
			</geometry>
		</collision>

		<xacro:inertial_cylinder mass="0.1" length="0.1" radius="0.1">
        	<origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
	</link>
	
	<gazebo reference="wheel2_link">
		<material>Gazebo/Black</material>
	</gazebo>

	<!-- WHEEL3 -->
	<joint name="wheel3_joint" type="continuous">
		<parent link="base_link"/>
		<child link="wheel3_link"/>
		<origin xyz="-0.2 0.25 0" rpy="${-pi/2} 0 0"/>
		<axis xyz="0 0 1"/>
		<limit effort="80" velocity="20" />
	    <dynamics damping="1.0" friction="1.0" />
	</joint>

	<link name="wheel3_link">
		<visual>
			<origin xyz="0 0 0.0167" rpy="0 0 0"/>
			<geometry>
				<mesh filename="package://four_wheeled_robot/meshes/wheel3_Link.STL" scale="2.56 2.56 3.333"/>
			</geometry>
			<material name="yellow"/>
		</visual>
		<visual>
			<origin xyz="0 0 -0.005" rpy="0 0 0"/>
			<geometry>
				<mesh filename="package://four_wheeled_robot/meshes/tire3_Link.STL" scale="2.04 2.04 3.333"/>
			</geometry>
			<material name="black"/>
		</visual>
		<!-- Primitive fallback so wheel remains visible if mesh loading fails -->
		<visual>
			<geometry>
				<cylinder radius="0.1" length="0.1"/>
			</geometry>
			<material name="black"/>
		</visual>

		<collision>
			<geometry>
				<cylinder radius="0.1" length="0.1"/>
			</geometry>
		</collision>

		<xacro:inertial_cylinder mass="0.1" length="0.1" radius="0.1">
        	<origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
	</link>

	<gazebo reference="wheel3_link">
		<material>Gazebo/Black</material>
	</gazebo>	

	<!-- WHEEL4 -->
	<joint name="wheel4_joint" type="continuous">
		<parent link="base_link"/>
		<child link="wheel4_link"/>
		<origin xyz="-0.2 -0.25 0" rpy="${pi/2} 0 0"/>
		<axis xyz="0 0 -1"/>
		<limit effort="80" velocity="20" />
	    <dynamics damping="1.0" friction="1.0" />
	</joint>

	<link name="wheel4_link">
		<visual>
			<origin xyz="0 0 0.0167" rpy="0 0 0"/>
			<geometry>
				<mesh filename="package://four_wheeled_robot/meshes/wheel4_Link.STL" scale="2.56 2.56 3.333"/>
			</geometry>
			<material name="yellow"/>
		</visual>
		<visual>
			<origin xyz="0 0 0.045" rpy="0 0 0"/>
			<geometry>
				<mesh filename="package://four_wheeled_robot/meshes/tire4_Link.STL" scale="2.04 2.04 3.333"/>
			</geometry>
			<material name="black"/>
		</visual>
		<!-- Primitive fallback so wheel remains visible if mesh loading fails -->
		<visual>
			<geometry>
				<cylinder radius="0.1" length="0.1"/>
			</geometry>
			<material name="black"/>
		</visual>

		<collision>
			<geometry>
				<cylinder radius="0.1" length="0.1"/>
			</geometry>
		</collision>

		<xacro:inertial_cylinder mass="0.1" length="0.1" radius="0.1">
        	<origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
	</link>

	<gazebo reference="wheel4_link">
		<material>Gazebo/Black</material>
	</gazebo>
</robot>
