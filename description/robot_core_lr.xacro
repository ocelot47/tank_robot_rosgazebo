<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
	
	<xacro:include filename="inertial_macros.xacro"/>	

	<material name="chassis_metal">
		<color rgba="0.18 0.22 0.27 1"/>
	</material>

	<material name="chassis_rubber">
		<color rgba="0.03 0.03 0.04 1"/>
	</material>

	<material name="chassis_panel">
		<color rgba="0.98 0.45 0.08 1"/>
	</material>

	<material name="chassis_clear">
		<color rgba="0.55 0.75 0.95 0.45"/>
	</material>

	<material name="wheel_hub">
		<color rgba="0.95 0.70 0.15 1"/>
	</material>

	<material name="wheel_tire">
		<color rgba="0.02 0.02 0.02 1"/>
	</material>

	<material name="lidar_accent">
		<color rgba="0.10 0.85 0.75 1"/>
	</material>

	<!-- DAE meshes keep the original visual look -->
	<xacro:property name="elm_scale" value="1.0"/>

	<!-- BASE LINK -->
	<link name="base_link">
		
	</link>

	<!-- Nav2 AMCL default uses base_footprint as robot base frame -->
	<joint name="base_footprint_joint" type="fixed">
		<parent link="base_link"/>
		<child link="base_footprint"/>
		<origin xyz="0 0 -0.10" rpy="0 0 0"/>
	</joint>

	<link name="base_footprint"/>

	<!-- Low-mounted ballast to keep CoM near the ground and reduce roll-over -->
	<joint name="ballast_joint" type="fixed">
		<parent link="base_link"/>
		<child link="ballast_link"/>
		<origin xyz="0 0 0.03" rpy="0 0 0"/>
	</joint>

	<link name="ballast_link">
		<xacro:inertial_box mass="2.2" x="0.25" y="0.18" z="0.04">
        	<origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
	</link>
	
	<!-- CHASSIS -->
	<joint name="chassis_joint" type="fixed">
		<parent link="base_link"/>
		<child link="chassis_link"/>
		<origin xyz="0 0 0"/>
	</joint>

		<link name="chassis_link">
		<visual>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
					<mesh filename="package://four_wheeled_robot/meshes/BaseMetal.dae" scale="${elm_scale} ${elm_scale} ${elm_scale}"/>
			</geometry>
			<material name="chassis_metal"/>
		</visual>
		<visual>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
					<mesh filename="package://four_wheeled_robot/meshes/BaseRubber.dae" scale="${elm_scale} ${elm_scale} ${elm_scale}"/>
			</geometry>
			<material name="chassis_rubber"/>
		</visual>
		<visual>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
					<mesh filename="package://four_wheeled_robot/meshes/BasePlastic.dae" scale="${elm_scale} ${elm_scale} ${elm_scale}"/>
			</geometry>
			<material name="chassis_panel"/>
		</visual>
			<visual>
				<origin xyz="0 0 0" rpy="0 0 0"/>
				<geometry>
						<mesh filename="package://four_wheeled_robot/meshes/BaseClear.dae" scale="${elm_scale} ${elm_scale} ${elm_scale}"/>
				</geometry>
				<material name="chassis_clear"/>
			</visual>
		<collision>
			<origin xyz="0 0 0.0875"/>
			<geometry>
				<box size="0.8 0.389 0.171"/>
			</geometry>
		</collision>

		<xacro:inertial_box mass="0.5" x="0.8" y="0.389" z="0.171">
        	<origin xyz="0 0 0.0875" rpy="0 0 0"/>
        </xacro:inertial_box>
	</link>

	<!-- LIDAR -->
	<joint name="lidar_joint" type="fixed">
		<parent link="chassis_link"/>
		<child link="lidar_link"/>
		<origin xyz="0 0 0.18" rpy="0 0 0"/>
	</joint>

	<link name="lidar_link">
		<visual>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
				<cylinder radius="0.03" length="0.04"/>
			</geometry>
			<material name="lidar_accent"/>
		</visual>
		<collision>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
				<cylinder radius="0.03" length="0.04"/>
			</geometry>
		</collision>
		<xacro:inertial_cylinder mass="0.05" length="0.04" radius="0.03">
        	<origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
	</link>

		<gazebo reference="lidar_link">
			<sensor name="lidar_sensor" type="ray">
				<always_on>true</always_on>
					<visualize>true</visualize>
				<update_rate>8</update_rate>
			<pose>0 0 0 0 0 0</pose>
			<ray>
				<scan>
					<horizontal>
						<samples>360</samples>
						<resolution>1</resolution>
						<min_angle>-3.14159</min_angle>
						<max_angle>3.14159</max_angle>
					</horizontal>
				</scan>
				<range>
					<min>0.12</min>
					<max>8.0</max>
					<resolution>0.01</resolution>
				</range>
				<noise>
					<type>gaussian</type>
					<mean>0.0</mean>
					<stddev>0.01</stddev>
				</noise>
			</ray>
				<plugin name="gazebo_ros_lidar" filename="libgazebo_ros_ray_sensor.so">
					<ros>
						<remapping>~/out:=/four_wheeled_robot/scan</remapping>
					</ros>
					<output_type>sensor_msgs/LaserScan</output_type>
					<frame_name>lidar_link</frame_name>
			</plugin>
		</sensor>
	</gazebo>

	<!-- WHEEL1 -->
	<joint name="wheel1_joint" type="continuous">
		<parent link="base_link"/>
		<child link="wheel1_link"/>
		<origin xyz="0.2 0.25 0" rpy="0 0 0"/>
		<axis xyz="0 1 0"/>
		<limit effort="80" velocity="20" />
	    <dynamics damping="1.0" friction="1.0" />
	</joint>

		<link name="wheel1_link">
		<visual>
			<origin xyz="0 0 0" rpy="0 0 ${pi}"/>
			<geometry>
					<mesh filename="package://four_wheeled_robot/meshes/HubMotor.dae" scale="${elm_scale} ${elm_scale} ${elm_scale}"/>
			</geometry>
			<material name="wheel_hub"/>
		</visual>
			<visual>
				<origin xyz="0 0 0" rpy="0 0 ${pi}"/>
				<geometry>
						<mesh filename="package://four_wheeled_robot/meshes/RubberWheel.dae" scale="${elm_scale} ${elm_scale} ${elm_scale}"/>
				</geometry>
				<material name="wheel_tire"/>
			</visual>
		<collision>
			<origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
			<geometry>
				<cylinder radius="0.1" length="0.1"/>
			</geometry>
		</collision>
		
		<xacro:inertial_cylinder mass="0.1" length="0.1" radius="0.1">
	        	<origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
	        </xacro:inertial_cylinder>
	</link>
	
	<!-- WHEEL2 -->
	<joint name="wheel2_joint" type="continuous">
		<parent link="base_link"/>
		<child link="wheel2_link"/>
		<origin xyz="0.2 -0.25 0" rpy="0 0 0"/>
		<axis xyz="0 1 0"/>
		<limit effort="80" velocity="20" />
	    <dynamics damping="1.0" friction="1.0" />
	</joint>

		<link name="wheel2_link">
		<visual>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
					<mesh filename="package://four_wheeled_robot/meshes/HubMotor.dae" scale="${elm_scale} ${elm_scale} ${elm_scale}"/>
			</geometry>
			<material name="wheel_hub"/>
		</visual>
			<visual>
				<origin xyz="0 0 0" rpy="0 0 0"/>
				<geometry>
						<mesh filename="package://four_wheeled_robot/meshes/RubberWheel.dae" scale="${elm_scale} ${elm_scale} ${elm_scale}"/>
				</geometry>
				<material name="wheel_tire"/>
			</visual>
		<collision>
			<origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
			<geometry>
				<cylinder radius="0.1" length="0.1"/>
			</geometry>
		</collision>

		<xacro:inertial_cylinder mass="0.1" length="0.1" radius="0.1">
	        	<origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
	        </xacro:inertial_cylinder>
	</link>
	
	<!-- WHEEL3 -->
	<joint name="wheel3_joint" type="continuous">
		<parent link="base_link"/>
		<child link="wheel3_link"/>
		<origin xyz="-0.2 0.25 0" rpy="0 0 0"/>
		<axis xyz="0 1 0"/>
		<limit effort="80" velocity="20" />
	    <dynamics damping="1.0" friction="1.0" />
	</joint>

		<link name="wheel3_link">
		<visual>
			<origin xyz="0 0 0" rpy="0 0 ${pi}"/>
			<geometry>
					<mesh filename="package://four_wheeled_robot/meshes/HubMotor.dae" scale="${elm_scale} ${elm_scale} ${elm_scale}"/>
			</geometry>
			<material name="wheel_hub"/>
		</visual>
			<visual>
				<origin xyz="0 0 0" rpy="0 0 ${pi}"/>
				<geometry>
						<mesh filename="package://four_wheeled_robot/meshes/RubberWheel.dae" scale="${elm_scale} ${elm_scale} ${elm_scale}"/>
				</geometry>
				<material name="wheel_tire"/>
			</visual>
		<collision>
			<origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
			<geometry>
				<cylinder radius="0.1" length="0.1"/>
			</geometry>
		</collision>

		<xacro:inertial_cylinder mass="0.1" length="0.1" radius="0.1">
	        	<origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
	        </xacro:inertial_cylinder>
	</link>

	<!-- WHEEL4 -->
	<joint name="wheel4_joint" type="continuous">
		<parent link="base_link"/>
		<child link="wheel4_link"/>
		<origin xyz="-0.2 -0.25 0" rpy="0 0 0"/>
		<axis xyz="0 1 0"/>
		<limit effort="80" velocity="20" />
	    <dynamics damping="1.0" friction="1.0" />
	</joint>

			<link name="wheel4_link">
		<visual>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
					<mesh filename="package://four_wheeled_robot/meshes/HubMotor.dae" scale="${elm_scale} ${elm_scale} ${elm_scale}"/>
			</geometry>
			<material name="wheel_hub"/>
		</visual>
			<visual>
				<origin xyz="0 0 0" rpy="0 0 0"/>
				<geometry>
						<mesh filename="package://four_wheeled_robot/meshes/RubberWheel.dae" scale="${elm_scale} ${elm_scale} ${elm_scale}"/>
				</geometry>
				<material name="wheel_tire"/>
			</visual>
		<collision>
			<origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
			<geometry>
				<cylinder radius="0.1" length="0.1"/>
			</geometry>
		</collision>

		<xacro:inertial_cylinder mass="0.1" length="0.1" radius="0.1">
	        	<origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
	        </xacro:inertial_cylinder>
		</link>

	</robot>
